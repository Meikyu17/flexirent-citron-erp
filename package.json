{
  "name": "flexirent-citron-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "./scripts/dev-local.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose -f docker-compose.db.yml --env-file .env.db up -d",
    "db:down": "docker compose -f docker-compose.db.yml --env-file .env.db down",
    "db:reset": "./scripts/reset-db-local.sh",
    "db:logs": "docker compose -f docker-compose.db.yml --env-file .env.db logs -f db",
    "db:seed:demo-fleet": "node scripts/seed-demo-fleet.mjs",
    "db:clear:demo-fleet": "node scripts/clear-demo-fleet.mjs",
    "docker:image:build": "./scripts/docker-build-image.sh"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "jose": "^6.2.2",
    "next": "16.2.0",
    "prisma": "^6.19.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
